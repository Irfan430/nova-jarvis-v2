{
  "name": "nova-jarvis",
  "version": "0.1.0",
  "description": "Local-first Jarvis daemon with OpenRouter brain, visible browser control, and split desktop/mobile web UI.",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/link-src-package.mjs && node scripts/generate-js-shims.mjs",
    "dev": "tsx watch src/app/server.ts",
    "start": "node dist/app/server.js",
    "build": "tsc --project tsconfig.build.json",
    "validate:dist-runtime": "node --import tsx/esm scripts/validate-dist-runtime.mjs",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src/app/server.ts src/app/cli.ts src/assistant src/constants/jarvisBrainPrompt.ts src/orchestrator src/runtime/browser-manager.ts src/runtime/config.ts src/runtime/daemon.ts src/runtime/diagnostics.ts src/runtime/imported-tool-worker.ts src/runtime/model-router.ts src/runtime/persistence.ts src/runtime/policy.ts src/runtime/reference-tool-catalog.ts src/runtime/tool-bridge.ts src/ui/web src/voice/speaker.ts src/tests",
    "lint:fix": "biome check --write src/app/server.ts src/app/cli.ts src/assistant src/constants/jarvisBrainPrompt.ts src/orchestrator src/runtime/browser-manager.ts src/runtime/config.ts src/runtime/daemon.ts src/runtime/diagnostics.ts src/runtime/imported-tool-worker.ts src/runtime/model-router.ts src/runtime/persistence.ts src/runtime/policy.ts src/runtime/reference-tool-catalog.ts src/runtime/tool-bridge.ts src/ui/web src/voice/speaker.ts src/tests",
    "test": "vitest run",
    "tools:smoke": "node --import tsx/esm scripts/tool-import-smoke.mjs",
    "tools:live": "node --import tsx/esm scripts/live-tool-execution.mjs",
    "tools:live:extended": "node --import tsx/esm scripts/live-tool-execution-extended.mjs",
    "doctor": "tsx src/app/cli.ts doctor",
    "doctor:dist": "node dist/app/cli.js doctor",
    "daemon:start": "tsx src/app/cli.ts start",
    "daemon:start:dist": "node dist/app/cli.js start",
    "daemon:stop": "tsx src/app/cli.ts stop",
    "daemon:stop:dist": "node dist/app/cli.js stop",
    "daemon:status": "tsx src/app/cli.ts status",
    "daemon:status:dist": "node dist/app/cli.js status",
    "autostart:setup": "tsx src/app/cli.ts setup-autostart"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@anthropic-ai/sandbox-runtime": "^0.0.44",
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1024.0",
    "@commander-js/extra-typings": "^13.1.0",
    "@growthbook/growthbook": "^1.6.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.57.2",
    "@opentelemetry/core": "^1.30.1",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.57.2",
    "@opentelemetry/sdk-metrics": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@sentry/node": "^8.55.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "asciichart": "^1.5.25",
    "auto-bind": "^5.0.1",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "cli-boxes": "^3.0.0",
    "code-excerpt": "^4.0.0",
    "color-diff-napi": "file:vendor/color-diff-napi",
    "diff": "^7.0.0",
    "drizzle-orm": "^0.45.2",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "figures": "^6.1.0",
    "fuse.js": "^7.3.0",
    "google-auth-library": "^10.6.2",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^8.0.0",
    "ignore": "^6.0.2",
    "indent-string": "^5.0.0",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.18.1",
    "lru-cache": "^11.2.7",
    "marked": "^15.0.12",
    "node-pty": "^1.1.0",
    "p-map": "^7.0.4",
    "picomatch": "^4.0.4",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-reconciler": "^0.31.0",
    "semver": "^7.7.4",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^3.2.0",
    "tree-kill": "^1.2.2",
    "tsx": "^4.21.0",
    "turndown": "^7.2.4",
    "type-fest": "^4.41.0",
    "undici": "^7.24.7",
    "usehooks-ts": "^3.1.1",
    "vitest": "^4.1.2",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "wrap-ansi": "^9.0.2",
    "ws": "^8.20.0",
    "xss": "^1.0.15",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.0",
    "@types/picomatch": "^3.0.2",
    "@types/react": "^19.2.14",
    "@types/semver": "^7.7.1",
    "@types/stack-utils": "^2.0.3",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0"
  }
}
