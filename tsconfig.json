{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "baseUrl": "."
  },
  "include": [
    "src/app/server.ts",
    "src/app/cli.ts",
    "src/assistant/brain.ts",
    "src/assistant/clarification-policy.ts",
    "src/assistant/goal-understanding.ts",
    "src/assistant/input-helpers.ts",
    "src/assistant/interaction-mode.ts",
    "src/assistant/reflection.ts",
    "src/assistant/response-policy.ts",
    "src/assistant/sessionHistory.ts",
    "src/assistant/session-intel.ts",
    "src/assistant/tool-brain.ts",
    "src/assistant/types.ts",
    "src/assistant/verifier.ts",
    "src/assistant/world-model.ts",
    "src/constants/jarvisBrainPrompt.ts",
    "src/constants/plannerPrompt.ts",
    "src/orchestrator/follow-up.ts",
    "src/orchestrator/orchestrator.ts",
    "src/orchestrator/types.ts",
    "src/orchestrator/workflows.ts",
    "src/runtime/browser-manager.ts",
    "src/runtime/config.ts",
    "src/runtime/daemon.ts",
    "src/runtime/diagnostics.ts",
    "src/runtime/imported-tool-worker.ts",
    "src/runtime/jarvis-memory.ts",
    "src/runtime/model-router.ts",
    "src/runtime/persistence.ts",
    "src/runtime/known-sites.ts",
    "src/runtime/policy.ts",
    "src/runtime/reference-tool-catalog.ts",
    "src/runtime/tool-bridge.ts",
    "src/runtime/tool-registry.ts",
    "src/ui/web/desktop.ts",
    "src/ui/web/mobile.ts",
    "src/voice/speaker.ts",
    "src/tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "src/tools/**", "src/commands/**"]
}
